# ── Node ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Next.js ────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/.env*.local

# ── Build outputs ──────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ── Environment & secrets ──────────────────────────────
.env
.env.local
.env.production
.env.development
# Keep .env.example tracked
!.env.example

# ── Docker ─────────────────────────────────────────────
# Never commit docker override files with secrets
docker-compose.override.yml

# ── Prisma ─────────────────────────────────────────────
# Track migration history for deterministic deploys

# ── Logs ───────────────────────────────────────────────
logs/
*.log

# ── SSL / Certbot ──────────────────────────────────────
nginx/certbot/conf/
nginx/certbot/www/

# ── OS & editor ────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo

# ── Test coverage ──────────────────────────────────────
coverage/
.nyc_output/

# ── Uploads / media ────────────────────────────────────
uploads/
